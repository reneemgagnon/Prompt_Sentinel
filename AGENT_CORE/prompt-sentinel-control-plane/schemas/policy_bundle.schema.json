  "required": ["policy_id", "version", "tenant", "bundle"],
  "properties": {
    "policy_id": {"type": "string"},
    "version": {"type": "string"},
    "tenant": {"type": "string"},
    "labels": {
      "type": "array",
      "items": {"type": "string"}
    },
    "bundle": {"type": "object"}
  }
}
